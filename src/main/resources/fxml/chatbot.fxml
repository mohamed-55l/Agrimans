<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.chatbot.controllers.ChatbotController"
            stylesheets="@css/admin-dark.css"
            styleClass="main-background">

    <!-- TOP: Titre -->
    <top>
        <VBox spacing="5" style="-fx-padding: 20 30;">
            <Label text="🤖 Assistant Agricole Intelligent" styleClass="page-title"/>
            <Label text="Posez vos questions sur l'agriculture, les équipements, les cultures..." styleClass="page-subtitle"/>
        </VBox>
    </top>

    <!-- CENTER: Zone de chat + questions -->
    <center>
        <HBox spacing="20" style="-fx-padding: 0 30 30 30;">

            <!-- Zone des messages -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-padding: 20;">
                <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background: transparent; -fx-control-inner-background: #1E293B; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="messagesContainer" spacing="15" style="-fx-padding: 10 10 20 10; -fx-background-color: transparent;"/>
                </ScrollPane>

                <!-- Zone de saisie -->
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="inputMessage" promptText="Tapez votre question ici..."
                               style="-fx-background-radius: 20; -fx-padding: 10 15;" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnEnvoyer" text="Envoyer" onAction="#envoyerMessage"
                            styleClass="btn-primary" style="-fx-background-radius: 20; -fx-padding: 10 25;"/>
                    <Button text="🗑️" onAction="#effacerConversation"
                            styleClass="btn-danger" style="-fx-background-radius: 20; -fx-padding: 10 15;"/>
                </HBox>
            </VBox>

            <!-- Questions fréquentes (sidebar) -->
            <VBox spacing="15" prefWidth="300" styleClass="card" style="-fx-padding: 20;">
                <Label text="📋 Questions fréquentes" styleClass="card-title"/>
                
                <ListView fx:id="questionsListView" prefHeight="250" 
                          style="-fx-background-color: #0F172A; -fx-border-color: #334155; -fx-border-radius: 8; -fx-control-inner-background: #0F172A;"/>
                <Label text="(Double-cliquez pour poser la question)"
                       style="-fx-text-fill: #94A3B8; -fx-font-size: 11px;"/>

                <Separator/>

                <Label text="🤖 Astuces" styleClass="card-title"/>
                <VBox spacing="8" style="-fx-padding: 10 0 0 0;">
                    <HBox spacing="10"><Label text="•" style="-fx-text-fill: #10B981;"/><Label text="Tapez 'aide' pour voir les commandes" style="-fx-text-fill: #CBD5E1;" wrapText="true"/></HBox>
                    <HBox spacing="10"><Label text="•" style="-fx-text-fill: #10B981;"/><Label text="Questions en français" style="-fx-text-fill: #CBD5E1;" wrapText="true"/></HBox>
                    <HBox spacing="10"><Label text="•" style="-fx-text-fill: #10B981;"/><Label text="Réponses instantanées" style="-fx-text-fill: #CBD5E1;" wrapText="true"/></HBox>
                </VBox>
            </VBox>
            
        </HBox>
    </center>

</BorderPane>