<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="750" prefWidth="900" spacing="20" style="-fx-background-color: transparent; -fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="modules.demande.controllers.DemandeController">

    <!-- ===================================================== -->
    <!-- TITRE DE LA PAGE -->
    <!-- ===================================================== -->
    <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;" text="📋 Gestion des demandes d'équipement" />

    <Separator />

    <!-- ===================================================== -->
    <!-- PARTIE 1: LISTE DE MES DEMANDES (EN HAUT) -->
    <!-- ===================================================== -->
    <VBox prefHeight="349.0" prefWidth="860.0" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;" text="📋 Mes demandes" />

        <TableView fx:id="tableMesDemandes" prefHeight="300">
            <columns>
                <TableColumn fx:id="colEquipement" prefWidth="150" text="Équipement" />
                <TableColumn fx:id="colDescription" prefWidth="300" text="Description" />
                <TableColumn fx:id="colDate" prefWidth="100" text="Date" />
                <TableColumn fx:id="colStatut" prefWidth="100" text="Statut" />
                <TableColumn fx:id="colReponse" prefWidth="150" text="Réponse" />
                <TableColumn fx:id="colAction" prefWidth="150" text="Actions" />
            </columns>
        </TableView>

        <!-- Légende des statuts -->
        <HBox alignment="CENTER" spacing="20">
            <HBox spacing="5"><Label style="-fx-text-fill: #f39c12; -fx-font-size: 14px;" text="●" /> <Label text="En attente" /></HBox>
            <HBox spacing="5"><Label style="-fx-text-fill: #27ae60; -fx-font-size: 14px;" text="●" /> <Label text="Accepté" /></HBox>
            <HBox spacing="5"><Label style="-fx-text-fill: #e74c3c; -fx-font-size: 14px;" text="●" /> <Label text="Refusé" /></HBox>
        </HBox>

    </VBox>

    <!-- ===================================================== -->
    <!-- PARTIE 2: FORMULAIRE DE DEMANDE (EN BAS) -->
    <!-- ===================================================== -->
    <VBox prefHeight="275.0" prefWidth="860.0" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;" text="➕ Faire une nouvelle demande" />

        <!-- Type de demande -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label style="-fx-font-weight: bold; -fx-min-width: 100;" text="Type :" />
            <HBox spacing="15">
                <RadioButton fx:id="radioSelectionner" selected="true" text="Sélectionner un équipement" />
                <RadioButton fx:id="radioSaisir" text="Saisir le nom de l'équipement" />
            </HBox>
        </HBox>

        <!-- Sélectionner un équipement -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label style="-fx-font-weight: bold; -fx-min-width: 100;" text="Équipement :" />
            <ComboBox fx:id="cbEquipement" prefWidth="450" promptText="Choisir un équipement..." />
        </HBox>

        <!-- Saisir le nom -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label style="-fx-font-weight: bold; -fx-min-width: 100;" text="Nom :" />
            <TextField fx:id="tfNomEquipement" disable="true" prefWidth="450" promptText="Nom de l'équipement recherché" />
        </HBox>

        <!-- Quantité -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label style="-fx-font-weight: bold; -fx-min-width: 100;" text="Quantité :" />
            <TextField fx:id="tfQuantite" prefWidth="100" text="1" />
        </HBox>

        <!-- Description -->
        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Description / Justification :" />
            <TextArea fx:id="taDescription" prefRowCount="4" promptText="Expliquez pourquoi vous avez besoin de cet équipement..." />
        </VBox>

        <!-- Message d'erreur -->
        <Label fx:id="lblError" managed="false" style="-fx-text-fill: #e74c3c;" />

        <!-- Boutons -->
        <HBox alignment="CENTER" spacing="15">
            <Button onAction="#validerDemande" prefWidth="180" style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;" text="✅ Envoyer la demande" />
            <Button onAction="#annuler" prefWidth="120" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;" text="❌ Annuler" />
        </HBox>

    </VBox>

</VBox>
