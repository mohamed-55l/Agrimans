<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.sentiment.controllers.SentimentController"
            style="-fx-background-color: #F0E8D8;">

    <!-- TOP: Titre -->
    <top>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #2E3D27;">
            <Label text="🧠 Analyse de sentiments"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <HBox spacing="20" alignment="CENTER_LEFT">
                <Button fx:id="btnAnalyserToutes" text="🔍 Analyser toutes les reviews" onAction="#analyserToutes"
                        style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                <Button text="📊 Voir détails" onAction="#voirDetails"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Filtrer:" style="-fx-text-fill: white;"/>
                <ComboBox fx:id="cbFiltre" prefWidth="150"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER: Contenu principal -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- Cartes statistiques -->
            <HBox spacing="15" alignment="CENTER">

                <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);"
                      prefWidth="160" alignment="CENTER" spacing="10">
                    <Label text="📊" style="-fx-font-size: 30px;"/>
                    <Label text="Total analyses" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="lblTotalAnalyses" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                      prefWidth="160" alignment="CENTER" spacing="10">
                    <Label text="😊" style="-fx-font-size: 30px;"/>
                    <Label text="Positifs" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="lblPositifs" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                      prefWidth="160" alignment="CENTER" spacing="10">
                    <Label text="😞" style="-fx-font-size: 30px;"/>
                    <Label text="Négatifs" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="lblNegatifs" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                      prefWidth="160" alignment="CENTER" spacing="10">
                    <Label text="😐" style="-fx-font-size: 30px;"/>
                    <Label text="Neutres" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="lblNeutres" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                      prefWidth="160" alignment="CENTER" spacing="10">
                    <Label text="⚠️" style="-fx-font-size: 30px;"/>
                    <Label text="Warnings" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="lblWarnings" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                </VBox>

            </HBox>

            <!-- Tableau des analyses -->
            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <Label text="📋 Résultats d'analyse"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>

                <TableView fx:id="tableAnalyses" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="colId" text="Review ID" prefWidth="80"/>
                        <TableColumn fx:id="colIcone" text="" prefWidth="40"/>
                        <TableColumn fx:id="colCommentaire" text="Commentaire" prefWidth="250"/>
                        <TableColumn fx:id="colSentiment" text="Sentiment" prefWidth="100"/>
                        <TableColumn fx:id="colScorePositif" text="Positif %" prefWidth="100"/>
                        <TableColumn fx:id="colScoreNegatif" text="Négatif %" prefWidth="100"/>
                        <TableColumn fx:id="colMotsCles" text="Mots détectés" prefWidth="200"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Légende -->
            <HBox spacing="20" alignment="CENTER">
                <HBox spacing="5"><Label text="●" style="-fx-text-fill: #27ae60; -fx-font-size: 14px;"/> <Label text="Positif"/></HBox>
                <HBox spacing="5"><Label text="●" style="-fx-text-fill: #e67e22; -fx-font-size: 14px;"/> <Label text="Négatif"/></HBox>
                <HBox spacing="5"><Label text="●" style="-fx-text-fill: #3498db; -fx-font-size: 14px;"/> <Label text="Neutre"/></HBox>
                <HBox spacing="5"><Label text="⚠️" style="-fx-font-size: 14px;"/> <Label text="Warning"/></HBox>
            </HBox>

        </VBox>
    </center>

    <!-- BOTTOM: Retour -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #2E3D27;">
            <Button text="🔙 Retour au Dashboard" onAction="#retourDashboard"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"/>
        </HBox>
    </bottom>

</BorderPane>