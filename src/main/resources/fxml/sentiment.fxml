<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.sentiment.controllers.SentimentController"
            stylesheets="@css/admin-dark.css"
            styleClass="main-background">

    <!-- TOP: Titre -->
    <top>
        <VBox spacing="15" style="-fx-padding: 20 30;">
            <Label text="🧠 Analyse de sentiments" styleClass="page-title"/>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button fx:id="btnAnalyserToutes" text="🔍 Analyser toutes les reviews" onAction="#analyserToutes" styleClass="btn-primary"/>
                <Button text="📊 Voir détails" onAction="#voirDetails" styleClass="btn-info"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Filtrer:" style="-fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                <ComboBox fx:id="cbFiltre" prefWidth="150"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER: Contenu principal -->
    <center>
        <VBox spacing="24" style="-fx-padding: 0 30 30 30;">

            <!-- Cartes statistiques -->
            <HBox spacing="15" alignment="CENTER_LEFT">

                <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="15" alignment="CENTER_LEFT">
                    <StackPane styleClass="kpi-icon-box, icon-blue">
                        <Label text="📊" styleClass="kpi-icon"/>
                    </StackPane>
                    <VBox spacing="2" alignment="CENTER_LEFT">
                        <Label text="TOTAL ANALYSES" styleClass="kpi-title"/>
                        <Label fx:id="lblTotalAnalyses" text="0" styleClass="kpi-value"/>
                    </VBox>
                </HBox>

                <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="15" alignment="CENTER_LEFT">
                    <StackPane styleClass="kpi-icon-box, icon-green">
                        <Label text="😊" styleClass="kpi-icon"/>
                    </StackPane>
                    <VBox spacing="2" alignment="CENTER_LEFT">
                        <Label text="POSITIFS" styleClass="kpi-title"/>
                        <Label fx:id="lblPositifs" text="0" styleClass="kpi-value" style="-fx-text-fill: #10B981;"/>
                    </VBox>
                </HBox>

                <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="15" alignment="CENTER_LEFT">
                    <StackPane styleClass="kpi-icon-box, icon-red">
                        <Label text="😞" styleClass="kpi-icon"/>
                    </StackPane>
                    <VBox spacing="2" alignment="CENTER_LEFT">
                        <Label text="NÉGATIFS" styleClass="kpi-title"/>
                        <Label fx:id="lblNegatifs" text="0" styleClass="kpi-value" style="-fx-text-fill: #EF4444;"/>
                    </VBox>
                </HBox>

                <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="15" alignment="CENTER_LEFT">
                    <StackPane styleClass="kpi-icon-box, icon-purple">
                        <Label text="😐" styleClass="kpi-icon"/>
                    </StackPane>
                    <VBox spacing="2" alignment="CENTER_LEFT">
                        <Label text="NEUTRES" styleClass="kpi-title"/>
                        <Label fx:id="lblNeutres" text="0" styleClass="kpi-value" style="-fx-text-fill: #8B5CF6;"/>
                    </VBox>
                </HBox>

                <HBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="15" alignment="CENTER_LEFT">
                    <StackPane styleClass="kpi-icon-box, icon-yellow">
                        <Label text="⚠️" styleClass="kpi-icon"/>
                    </StackPane>
                    <VBox spacing="2" alignment="CENTER_LEFT">
                        <Label text="WARNINGS" styleClass="kpi-title"/>
                        <Label fx:id="lblWarnings" text="0" styleClass="kpi-value" style="-fx-text-fill: #F59E0B;"/>
                    </VBox>
                </HBox>

            </HBox>

            <!-- Tableau des analyses -->
            <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                <Label text="📋 Résultats d'analyse" styleClass="card-title"/>

                <TableView fx:id="tableAnalyses" styleClass="modern-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="Review ID" prefWidth="80"/>
                        <TableColumn fx:id="colIcone" text="" prefWidth="40"/>
                        <TableColumn fx:id="colCommentaire" text="Commentaire" prefWidth="350"/>
                        <TableColumn fx:id="colSentiment" text="Sentiment" prefWidth="120"/>
                        <TableColumn fx:id="colScorePositif" text="Positif %" prefWidth="100"/>
                        <TableColumn fx:id="colScoreNegatif" text="Négatif %" prefWidth="100"/>
                        <TableColumn fx:id="colMotsCles" text="Mots détectés" prefWidth="250"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                    </columns>
                </TableView>
                
                <!-- Légende -->
                <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                    <HBox spacing="5" alignment="CENTER"><Label text="●" style="-fx-text-fill: #10B981; -fx-font-size: 16px;"/><Label text="Positif" style="-fx-text-fill: #94A3B8;"/></HBox>
                    <HBox spacing="5" alignment="CENTER"><Label text="●" style="-fx-text-fill: #EF4444; -fx-font-size: 16px;"/><Label text="Négatif" style="-fx-text-fill: #94A3B8;"/></HBox>
                    <HBox spacing="5" alignment="CENTER"><Label text="●" style="-fx-text-fill: #8B5CF6; -fx-font-size: 16px;"/><Label text="Neutre" style="-fx-text-fill: #94A3B8;"/></HBox>
                    <HBox spacing="5" alignment="CENTER"><Label text="⚠️" style="-fx-font-size: 14px;"/><Label text="Warning" style="-fx-text-fill: #94A3B8;"/></HBox>
                </HBox>
            </VBox>

        </VBox>
    </center>
</BorderPane>