<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="modules.marketplace.controllers.ProductController"
            prefHeight="720" prefWidth="1100"
            style="-fx-background-color: #0F172A;">

    <!-- ══ Top Navigation Bar ══════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: #1E293B; -fx-border-color: #334155; -fx-border-width: 0 0 1 0;">

            <!-- Main nav row -->
            <HBox alignment="CENTER_LEFT" spacing="14"
                  style="-fx-padding: 14 24; -fx-background-color: #1E293B;">

                <!-- Branding -->
                <Label text="🌾" style="-fx-font-size: 22px;"/>
                <Label text="AGRIMANS" style="-fx-font-size: 17px; -fx-font-weight: 900; -fx-text-fill: #10B981;"/>
                <Label text="Marketplace" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #64748B;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- User name -->
                <Label fx:id="userNameLabel" text="Bienvenue"
                       style="-fx-font-size: 13px; -fx-text-fill: #94A3B8; -fx-font-weight: 500;"/>

                <!-- Currency selector — like Symfony dropdown -->
                <ComboBox fx:id="currencySelector"
                          style="-fx-background-color: #0F172A; -fx-text-base-color: #F1F5F9;
                                 -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-padding: 4 8; -fx-font-size: 12px; -fx-font-weight: bold;
                                 -fx-pref-width: 80px;"/>

                <!-- Cart button with badge -->
                <StackPane>
                    <Button text="🛒  Panier" onAction="#openCart"
                            style="-fx-background-color: rgba(16,185,129,0.15);
                                   -fx-text-fill: #10B981;
                                   -fx-border-color: rgba(16,185,129,0.4);
                                   -fx-border-width: 1; -fx-border-radius: 9;
                                   -fx-background-radius: 9;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-padding: 8 16; -fx-cursor: hand;"/>
                    <!-- Cart count badge -->
                    <Label fx:id="cartCountLabel" text="0"
                           style="-fx-background-color: #EF4444; -fx-text-fill: white;
                                  -fx-font-size: 9px; -fx-font-weight: bold;
                                  -fx-padding: 1 5; -fx-background-radius: 10;
                                  -fx-min-width: 18px; -fx-alignment: CENTER;"
                           StackPane.alignment="TOP_RIGHT"
                           visible="false"/>
                </StackPane>

                <!-- Chatbot -->
                <Button text="🤖  Assistant IA" onAction="#openChatbot"
                        style="-fx-background-color: rgba(59,130,246,0.15);
                               -fx-text-fill: #60A5FA;
                               -fx-border-color: rgba(59,130,246,0.4);
                               -fx-border-width: 1; -fx-border-radius: 9;
                               -fx-background-radius: 9;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>

            <!-- ── Search / Filter bar — mirrors Symfony filter form ── -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-padding: 10 24 14 24; -fx-background-color: #1E293B;">

                <Label text="🏪  Marketplace Agrimans"
                       style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #F1F5F9;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search box -->
                <TextField fx:id="searchField"
                           promptText="🔍  Rechercher produit, fournisseur..."
                           prefWidth="260"
                           style="-fx-background-color: #0F172A; -fx-text-fill: #F1F5F9;
                                  -fx-prompt-text-fill: #475569;
                                  -fx-border-color: #334155; -fx-border-radius: 9;
                                  -fx-background-radius: 9; -fx-padding: 9 14;
                                  -fx-font-size: 13px;"/>

                <!-- Category filter -->
                <ComboBox fx:id="categoryFilter"
                          prefWidth="180"
                          style="-fx-background-color: #0F172A; -fx-text-base-color: #F1F5F9;
                                 -fx-border-color: #334155; -fx-border-radius: 9;
                                 -fx-background-radius: 9; -fx-padding: 4 8;
                                 -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ══ Products Grid ═══════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-background: #0F172A;">
            <FlowPane fx:id="productsContainer"
                      hgap="18" vgap="18"
                      style="-fx-padding: 22 24; -fx-background-color: transparent;">
            </FlowPane>
        </ScrollPane>
    </center>

</BorderPane>
