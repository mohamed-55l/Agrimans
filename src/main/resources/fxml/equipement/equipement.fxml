<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="modules.equipement.controllers.EquipementController"
      spacing="20"
      style="-fx-background-color: transparent;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Titre -->
    <Label text="⚙️ Gestion des Équipements (Admin)"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>

    <!-- Tableau -->
    <TableView fx:id="tableEquipement"
               prefHeight="250"
               style="-fx-background-color: white; -fx-background-radius: 10;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="150"/>
            <TableColumn fx:id="colPrix" text="Prix (DT)" prefWidth="120"/>
            <TableColumn fx:id="colEtat" text="État" prefWidth="100"/>
            <TableColumn text="Propriétaire ID" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- Formulaire -->
    <TitledPane text="Ajouter / Modifier un équipement" expanded="true">
        <GridPane hgap="15" vgap="10" style="-fx-padding: 15;">
            <columnConstraints>
                <ColumnConstraints minWidth="100"/>
                <ColumnConstraints minWidth="250"/>
                <ColumnConstraints minWidth="200"/>
            </columnConstraints>

            <!-- Nom -->
            <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="tfNom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label fx:id="lblNomError" GridPane.rowIndex="0" GridPane.columnIndex="2"
                   textFill="red" visible="false"/>

            <!-- Type -->
            <Label text="Type:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="tfType" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Label fx:id="lblTypeError" GridPane.rowIndex="1" GridPane.columnIndex="2"
                   textFill="red" visible="false"/>

            <!-- Prix -->
            <Label text="Prix (DT):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="tfPrix" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label fx:id="lblPrixError" GridPane.rowIndex="2" GridPane.columnIndex="2"
                   textFill="red" visible="false"/>

            <!-- État -->
            <Label text="État:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cbEtat" GridPane.rowIndex="3" GridPane.columnIndex="1"
                      prefWidth="250"/>
            <Label fx:id="lblEtatError" GridPane.rowIndex="3" GridPane.columnIndex="2"
                   textFill="red" visible="false"/>

            <!-- 👉 NOUVEAU: Propriétaire (ComboBox des agriculteurs) -->
            <Label text="Propriétaire:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cbProprietaire" GridPane.rowIndex="4" GridPane.columnIndex="1"
                      prefWidth="250" promptText="Sélectionner un agriculteur"/>
            <Label fx:id="lblProprietaireError" GridPane.rowIndex="4" GridPane.columnIndex="2"
                   textFill="red" visible="false"/>

        </GridPane>
    </TitledPane>

    <!-- Boutons -->
    <HBox spacing="15" alignment="CENTER">
        <Button text="➕ Ajouter" onAction="#ajouterEquipement"
                style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"
                prefWidth="120"/>
        <Button text="✏️ Modifier" onAction="#modifierEquipement"
                style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"
                prefWidth="120"/>
        <Button text="🗑️ Supprimer" onAction="#supprimerEquipement"
                style="-fx-background-color: #2E3D27; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"
                prefWidth="120"/>
    </HBox>

</VBox>