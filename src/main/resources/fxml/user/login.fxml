<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.user.controllers.LoginController"
            style="-fx-background-color: linear-gradient(to bottom, #2E3D27, #4B8B3B);">

    <center>
        <VBox alignment="CENTER" spacing="30" maxWidth="400" maxHeight="500"
              style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 0);"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- Logo et titre -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="🌾" style="-fx-font-size: 60px;"/>
                <Label text="AGRIMANS" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                <Label text="Gestion Agricole" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
            </VBox>

            <!-- Formulaire -->
            <VBox spacing="15">
                <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                <TextField fx:id="tfEmail" promptText="exemple@agrimans.com"
                           style="-fx-background-radius: 5; -fx-padding: 10;"/>

                <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                <PasswordField fx:id="pfPassword" promptText="••••••••"
                               style="-fx-background-radius: 5; -fx-padding: 10;"/>

                <Label fx:id="lblError" text="Email ou mot de passe incorrect"
                       textFill="#e74c3c" visible="false" style="-fx-font-size: 12px;"/>

                <Button text="Se connecter" onAction="#handleLogin"
                        style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 12;"
                        maxWidth="Infinity"/>
            </VBox>

            <!-- Comptes de test -->
            <VBox spacing="5" style="-fx-background-color: #f5f5f5; -fx-padding: 15; -fx-background-radius: 10;">
                <Label text="Comptes de test:" style="-fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                <Label text="👑 Admin: admin@agrimans.com / 123" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                <Label text="👨‍🌾 Jean: jean@agrimans.com / 123" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                <Label text="👩‍🌾 Marie: marie@agrimans.com / 123" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            </VBox>

        </VBox>
    </center>
</BorderPane>