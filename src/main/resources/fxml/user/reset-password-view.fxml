<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="650" prefWidth="900" style="-fx-background-color: #0f6b3b;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="modules.user.controllers.ResetPasswordController">

    <!-- TITLE BAR -->
    <HBox alignment="CENTER_RIGHT" onMouseDragged="#handleMouseDragged" onMousePressed="#handleMousePressed" prefHeight="40" style="-fx-background-color: #1e1e1e;">

        <Label style="-fx-text-fill: white; -fx-padding: 0 0 0 15; -fx-font-weight: bold;" text="AGRI Samir" HBox.hgrow="ALWAYS" />

        <Button onMouseClicked="#handleMinimize" text="â€”" />
        <Button onMouseClicked="#handleMaximize" text="â˜" />
        <Button onMouseClicked="#handleClose" text="âœ•" />

    </HBox>

    <!-- MAIN -->
    <StackPane VBox.vgrow="ALWAYS">

        <HBox maxHeight="520" maxWidth="850" style="-fx-background-color: white;                      -fx-background-radius: 25;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0.3, 0, 8);">

            <!-- LEFT -->
            <VBox alignment="CENTER_LEFT" prefWidth="450" spacing="15" style="-fx-padding: 60;">

                <Label style="-fx-text-fill: #555555; -fx-font-size: 16px;" text="RÃ©cupÃ©ration" />

                <Label style="-fx-font-size: 34px; -fx-font-weight: bold;" text="Reset Password" />

                <Label text="Email" />
                <TextField fx:id="emailField" prefWidth="320" />

                <Label text="Code OTP" />
                <TextField fx:id="otpField" prefWidth="320" />

                <Label text="Nouveau mot de passe" />
                <PasswordField fx:id="newPasswordField" prefWidth="320" />

                <Label text="Confirmer mot de passe" />
                <PasswordField fx:id="confirmPasswordField" prefWidth="320" />

                <Label fx:id="messageLabel" style="-fx-text-fill:red; -fx-font-weight:bold;" />

                <Button onAction="#handleSendOTP" prefHeight="40" prefWidth="320" style="-fx-background-color:#2196F3; -fx-text-fill:white;" text="Envoyer OTP" />

                <Button onAction="#handleResetPassword" prefHeight="45" prefWidth="320" style="-fx-background-color:#0f6b3b; -fx-text-fill:white;" text="Reset Password" />

                <Hyperlink onAction="#goToLogin" text="Retour Login" />

            </VBox>

            <!-- RIGHT -->
            <VBox alignment="CENTER" prefWidth="450" style="-fx-background-color: #0f6b3b;                          -fx-background-radius: 0 25 25 0;">

                <ImageView fitHeight="520" preserveRatio="true">
                    <image>
                        <Image url="@../../image/login.png" />
                    </image>
                </ImageView>

            </VBox>

        </HBox>

    </StackPane>

</VBox>


