<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #0F172A; -fx-background: #0F172A;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.user.controllers.AdminDashboardController">

    <content>
        <VBox spacing="25" style="-fx-background-color: #0F172A;">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- En-tête مع زر Logout -->
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="👥  Gestion des Utilisateurs"
                           style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                    <Label text="Consultez، recherchez et modifiez les comptes utilisateurs."
                           style="-fx-font-size: 14px; -fx-text-fill: #94A3B8;"/>
                </VBox>

                <Button text="🚪 Déconnexion" onAction="#handleLogout"
                        style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>

            <!-- CONTAINER PRINCIPAL (يسمح بالتبديل بين الجدول والفورم) -->
            <StackPane fx:id="contentPane">

                <!-- VUE LISTE (الجدول) -->
                <VBox fx:id="usersView" spacing="20"
                      style="-fx-background-color: #1E293B; -fx-background-radius: 15; -fx-padding: 25;
                             -fx-border-color: #334155; -fx-border-radius: 15;">

                    <!-- Barre de recherche -->
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField"
                                   promptText="🔍  Rechercher un utilisateur..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #0F172A; -fx-border-color: #334155;
                                          -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12;"/>
                        <Button text="Rechercher" onAction="#handleSearch"
                                style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-padding: 12 25;"/>
                        <Button text="↺" onAction="#resetSearch"
                                style="-fx-background-color: transparent; -fx-text-fill: #94A3B8;
                                       -fx-border-color: #334155; -fx-border-radius: 10; -fx-padding: 12 15;"/>
                    </HBox>

                    <!-- Tableau (ثبت في الـ TableColumn IDs) -->
                    <TableView fx:id="usersTable" prefHeight="500" fixedCellSize="50">
                        <columns>
                            <TableColumn fx:id="colId"     text="ID"           prefWidth="60"/>
                            <TableColumn fx:id="colName"   text="Nom Complet"  prefWidth="180"/>
                            <TableColumn fx:id="colEmail"  text="Email"        prefWidth="220"/>
                            <TableColumn fx:id="colPhone"  text="Téléphone"    prefWidth="130"/>
                            <TableColumn fx:id="colRole"   text="Rôle"         prefWidth="100"/>
                            <TableColumn fx:id="colUpdate" text="Action"       prefWidth="120"/>
                            <TableColumn fx:id="colDelete" text="Supprimer"    prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
            </StackPane>
        </VBox>
    </content>
</ScrollPane>