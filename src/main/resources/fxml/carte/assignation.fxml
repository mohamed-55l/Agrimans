<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="modules.carte.controllers.AssignationController"
      spacing="20" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;"
      prefWidth="500" prefHeight="350">

    <Label text="📦 Assigner un équipement à un garage"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>

    <Separator/>

    <GridPane hgap="10" vgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="120"/>
            <ColumnConstraints minWidth="250"/>
        </columnConstraints>

        <Label text="Équipement :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbEquipement" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Garage :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbGarage" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Statut :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbStatut" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="250"/>

        <Label fx:id="lblError" GridPane.rowIndex="3" GridPane.columnIndex="1" textFill="red" managed="false"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER">
        <Button text="✅ Assigner" onAction="#assigner"
                style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"
                prefWidth="120"/>
        <Button text="❌ Annuler" onAction="#annuler"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"
                prefWidth="120"/>
    </HBox>

</VBox>