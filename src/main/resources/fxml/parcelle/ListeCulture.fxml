<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.parcelle.controllers.ListeCultureController">

    <children>

        <VBox spacing="15"
              AnchorPane.topAnchor="15"
              AnchorPane.bottomAnchor="15"
              AnchorPane.leftAnchor="15"
              AnchorPane.rightAnchor="15">

            <Label text="Liste des Cultures"
                   style="-fx-font-size:20px; -fx-font-weight:bold;" />

            <HBox spacing="10">
                <Button text="Ajouter" onAction="#openAjouterCulture"/>
                <Button text="Actualiser" onAction="#refreshTable"/>
                <Button text="Modifier" onAction="#openModifier"/>
                <Button text="Supprimer" onAction="#supprimerCulture"/>
            </HBox>

            <!-- 🔍 Barre de recherche -->
            <HBox spacing="10">
                <Label text="Rechercher par nom :" />
                <TextField fx:id="searchField"
                           promptText="Entrer le nom..."
                           prefWidth="250"/>
            </HBox>

            <TableView fx:id="tableCulture" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="colDatePlantation" text="Date Plantation" prefWidth="130"/>
                    <TableColumn fx:id="colDateRecolte" text="Date Récolte" prefWidth="130"/>
                    <TableColumn fx:id="colEtat" text="État" prefWidth="120"/>
                    <TableColumn fx:id="colParcelle" text="Parcelle ID" prefWidth="100"/>
                </columns>

            </TableView>

        </VBox>

    </children>

</AnchorPane>