<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.dashboard.controllers.UserDashboardController"
            fitToWidth="true"
            style="-fx-background-color: transparent;">

    <VBox spacing="25" style="-fx-background-color: transparent; -fx-padding: 20;">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="🌾" style="-fx-font-size: 40px;"/>
            <VBox>
                <Label fx:id="lblBienvenue"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                <Label text="Votre espace personnel"
                       style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="➕ Nouvelle demande" onAction="#nouvelleDemande"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 8 15;"/>
        </HBox>

        <!-- Statistiques -->
        <HBox spacing="15" alignment="CENTER">
            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);"
                  prefWidth="180" alignment="CENTER" spacing="10">
                <Label text="⚙️" style="-fx-font-size: 35px;"/>
                <Label text="Mes équipements" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                <Label fx:id="lblMesEquipements" text="0"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                  prefWidth="180" alignment="CENTER" spacing="10">
                <Label text="⭐" style="-fx-font-size: 35px;"/>
                <Label text="Mes reviews" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                <Label fx:id="lblMesReviews" text="0"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                  prefWidth="180" alignment="CENTER" spacing="10">
                <Label text="⚠️" style="-fx-font-size: 35px;"/>
                <Label text="En panne" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                <Label fx:id="lblMesPannes" text="0"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                  prefWidth="180" alignment="CENTER" spacing="10">
                <Label text="💰" style="-fx-font-size: 35px;"/>
                <Label text="Valeur totale" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                <Label fx:id="lblValeurTotale" text="0 DT"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;"
                  prefWidth="180" alignment="CENTER" spacing="10">
                <Label text="📋" style="-fx-font-size: 35px;"/>
                <Label text="Demandes en cours" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                <Label fx:id="lblDemandesEnCours" text="0"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
            </VBox>
        </HBox>

        <!-- Mes équipements -->
        <VBox spacing="10">
            <Label text="📋 Mes équipements"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>
            <TableView fx:id="tableMesEquipements" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colEquipNom" text="Nom" prefWidth="200"/>
                    <TableColumn fx:id="colEquipType" text="Type" prefWidth="150"/>
                    <TableColumn fx:id="colEquipPrix" text="Prix" prefWidth="120"/>
                    <TableColumn fx:id="colEquipEtat" text="État" prefWidth="100"/>
                    <TableColumn fx:id="colEquipAction" text="Actions" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>

        <!-- Mes reviews -->
        <VBox spacing="10">
            <Label text="⭐ Mes reviews"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>
            <TableView fx:id="tableMesReviews" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colReviewEquipement" text="Équipement" prefWidth="150"/>
                    <TableColumn fx:id="colReviewCommentaire" text="Commentaire" prefWidth="350"/>
                    <TableColumn fx:id="colReviewNote" text="Note" prefWidth="80"/>
                    <TableColumn fx:id="colReviewDate" text="Date" prefWidth="100"/>
                    <TableColumn fx:id="colReviewAction" text="Actions" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>