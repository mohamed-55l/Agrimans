<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.dashboard.controllers.UserDashboardController"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent;"
            stylesheets="@../../css/admin-dark.css">

    <VBox spacing="25" style="-fx-background-color: transparent; -fx-padding: 24;">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <StackPane style="-fx-background-radius: 12; -fx-background-color: rgba(16,185,129,0.15); -fx-padding: 16;">
                <Label text="👨‍🌾" style="-fx-font-size: 32px;"/>
            </StackPane>
            <VBox spacing="4">
                <Label fx:id="lblBienvenue"
                       style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #F1F5F9;"/>
                <Label text="Votre espace personnel"
                       style="-fx-font-size: 14px; -fx-text-fill: #94A3B8; -fx-font-weight: 500;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="➕  Nouvelle demande" onAction="#nouvelleDemande"
                    style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
        </HBox>

        <!-- Statistiques -->
        <HBox spacing="16" alignment="CENTER">
            <VBox style="-fx-background-color: #1E293B; -fx-background-radius: 16; -fx-padding: 20; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10, 0, 0, 4);"
                  HBox.hgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="🚜" style="-fx-font-size: 32px;"/>
                <Label text="Mes Équipements" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
                <Label fx:id="lblMesEquipements" text="0"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #F1F5F9;"/>
            </VBox>

            <VBox style="-fx-background-color: #1E293B; -fx-background-radius: 16; -fx-padding: 20; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10, 0, 0, 4);"
                  HBox.hgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="⭐" style="-fx-font-size: 32px;"/>
                <Label text="Mes Reviews" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
                <Label fx:id="lblMesReviews" text="0"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;"/>
            </VBox>

            <VBox style="-fx-background-color: #1E293B; -fx-background-radius: 16; -fx-padding: 20; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10, 0, 0, 4);"
                  HBox.hgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="⚠️" style="-fx-font-size: 32px;"/>
                <Label text="En Panne" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
                <Label fx:id="lblMesPannes" text="0"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #EF4444;"/>
            </VBox>

            <VBox style="-fx-background-color: #1E293B; -fx-background-radius: 16; -fx-padding: 20; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10, 0, 0, 4);"
                  HBox.hgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="💰" style="-fx-font-size: 32px;"/>
                <Label text="Valeur Totale" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
                <Label fx:id="lblValeurTotale" text="0 DT"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
            </VBox>

            <VBox style="-fx-background-color: #1E293B; -fx-background-radius: 16; -fx-padding: 20; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10, 0, 0, 4);"
                  HBox.hgrow="ALWAYS" alignment="CENTER" spacing="12">
                <Label text="📋" style="-fx-font-size: 32px;"/>
                <Label text="Demandes en cours" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
                <Label fx:id="lblDemandesEnCours" text="0"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
            </VBox>
        </HBox>

        <!-- Conteneur des tableaux -->
        <VBox spacing="24" style="-fx-background-color: #1E293B; -fx-background-radius: 16; -fx-padding: 24; -fx-border-color: #334155; -fx-border-width: 1; -fx-border-radius: 16;">
            
            <!-- Mes équipements -->
            <VBox spacing="12">
                <Label text="🚜   Mes Équipements"
                       style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #F1F5F9;"/>
                <TableView fx:id="tableMesEquipements" prefHeight="250" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colEquipNom" text="Nom" prefWidth="200"/>
                        <TableColumn fx:id="colEquipType" text="Type" prefWidth="150"/>
                        <TableColumn fx:id="colEquipPrix" text="Prix" prefWidth="120"/>
                        <TableColumn fx:id="colEquipEtat" text="État" prefWidth="120"/>
                        <TableColumn fx:id="colEquipAction" text="Actions" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>

            <Separator style="-fx-background-color: #334155;"/>

            <!-- Mes reviews -->
            <VBox spacing="12">
                <Label text="⭐   Mes Reviews"
                       style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #F1F5F9;"/>
                <TableView fx:id="tableMesReviews" prefHeight="250" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <columns>
                        <TableColumn fx:id="colReviewEquipement" text="Équipement" prefWidth="180"/>
                        <TableColumn fx:id="colReviewCommentaire" text="Commentaire" prefWidth="350"/>
                        <TableColumn fx:id="colReviewNote" text="Note" prefWidth="100"/>
                        <TableColumn fx:id="colReviewDate" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="colReviewAction" text="Actions" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>