<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.meteo.controllers.MeteoController"
            style="-fx-background-color: #F0E8D8;">

    <!-- TOP: Barre de recherche -->
    <top>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #2E3D27;">
            <Label text="🌤️ Météo Agricole"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="tfVille" promptText="Nom de la ville..."
                           style="-fx-background-radius: 5; -fx-padding: 10;" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbSuggestions" prefWidth="300" visible="false" managed="false"/>
                <Button fx:id="btnRechercher" text="🔍 Rechercher" onAction="#rechercherMeteo"
                        style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                <Button fx:id="btnMaPosition" text="📍 Ma position" onAction="#utiliserMaPosition"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                <Button fx:id="btnAjouterFavoris" text="⭐ Ajouter" onAction="#ajouterFavoris"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"/>
            </HBox>

            <Label fx:id="lblStatus" text="Prêt" style="-fx-text-fill: #7DBF6C; -fx-font-size: 12px;"/>
        </VBox>
    </top>

    <!-- CENTER: Contenu principal -->
    <center>
        <SplitPane dividerPositions="0.7" orientation="HORIZONTAL">

            <!-- Panneau gauche : Météo et prévisions -->
            <VBox spacing="20" style="-fx-padding: 20;">

                <!-- Carte météo actuelle -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblVille" text="Tunis"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                        <Label fx:id="lblDate" text="Loading..."
                               style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    </HBox>

                    <HBox spacing="30" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="5">
                            <Label fx:id="lblTemperature" text="--°C"
                                   style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #2E3D27;"/>
                            <Label fx:id="lblDescription" text="Chargement..."
                                   style="-fx-font-size: 16px;"/>
                        </VBox>

                        <VBox spacing="10">
                            <Label fx:id="lblRessentie" text="Ressentie: --°C"/>
                            <Label fx:id="lblHumidite" text="Humidité: --%"/>
                            <Label fx:id="lblPression" text="Pression: -- hPa"/>
                            <Label fx:id="lblVent" text="Vent: -- km/h"/>
                            <Label fx:id="lblPluie" text="Pluie: -- mm"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="lblConseil" text="Conseil agricole..."
                           style="-fx-background-color: #E8F5E9; -fx-padding: 15; -fx-background-radius: 5; -fx-wrap-text: true;"/>
                </VBox>

                <!-- Prévisions -->
                <VBox spacing="10">
                    <Label text="📅 Prévisions prochaines heures"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>
                    <HBox fx:id="previsionsContainer" spacing="10" alignment="CENTER"/>
                </VBox>

                <!-- Tableau des alertes -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🚨 Alertes météo"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✓ Tout marquer lu" onAction="#marquerToutesLues"
                                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 3; -fx-padding: 5 10;"/>
                    </HBox>

                    <TableView fx:id="tableAlertes" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="colIcone" text="" prefWidth="40"/>
                            <TableColumn fx:id="colTitre" text="Alerte" prefWidth="150"/>
                            <TableColumn fx:id="colMessage" text="Message" prefWidth="300"/>
                            <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <!-- Panneau droit : Historique et favoris -->
            <VBox spacing="20" style="-fx-padding: 20; -fx-background-color: white;">

                <!-- Historique -->
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📋 Historique"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🗑️ Vider" onAction="#viderHistorique"
                                style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 3; -fx-padding: 5 10;"/>
                    </HBox>
                    <ListView fx:id="listHistorique" prefHeight="150"
                              onMouseClicked="#rechercherHistorique"/>
                </VBox>

                <!-- Favoris -->
                <VBox spacing="10">
                    <Label text="⭐ Favoris"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>

                    <ListView fx:id="listFavoris" prefHeight="150"
                              onMouseClicked="#rechercherFavori"/>

                    <HBox spacing="10" alignment="CENTER">
                        <Button fx:id="btnSupprimerFavoris" text="❌ Supprimer" onAction="#supprimerFavoris"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 5; -fx-padding: 8 15;"
                                disable="true" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Villes suggérées -->
                <VBox spacing="10">
                    <Label text="🌾 Villes agricoles"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4B8B3B;"/>

                    <FlowPane hgap="5" vgap="5">
                        <Button text="Tunis" onAction="#rechercherVille" style="-fx-background-color: #E8F5E9; -fx-padding: 8 12;"/>
                        <Button text="Sfax" onAction="#rechercherVille" style="-fx-background-color: #E8F5E9; -fx-padding: 8 12;"/>
                        <Button text="Sousse" onAction="#rechercherVille" style="-fx-background-color: #E8F5E9; -fx-padding: 8 12;"/>
                        <Button text="Bizerte" onAction="#rechercherVille" style="-fx-background-color: #E8F5E9; -fx-padding: 8 12;"/>
                        <Button text="Béja" onAction="#rechercherVille" style="-fx-background-color: #E8F5E9; -fx-padding: 8 12;"/>
                        <Button text="Kairouan" onAction="#rechercherVille" style="-fx-background-color: #E8F5E9; -fx-padding: 8 12;"/>
                    </FlowPane>
                </VBox>

            </VBox>
        </SplitPane>
    </center>

    <!-- BOTTOM: Retour -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #2E3D27;">
            <Button text="🔙 Retour au Dashboard" onAction="#retourDashboard"
                    style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 14px; -fx-background-radius: 5; -fx-padding: 10 20;"/>
        </HBox>
    </bottom>

</BorderPane>