<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="modules.meteo.controllers.MeteoController"
            stylesheets="@css/admin-dark.css"
            styleClass="main-background">

    <!-- TOP: Barre de recherche -->
    <top>
        <VBox spacing="15" style="-fx-padding: 20 30;">
            <Label text="🌤️ Météo Agricole" styleClass="page-title"/>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="tfVille" promptText="Nom de la ville..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbSuggestions" prefWidth="300" visible="false" managed="false"/>
                <Button fx:id="btnRechercher" text="🔍 Rechercher" onAction="#rechercherMeteo" styleClass="btn-primary"/>
                <Button fx:id="btnMaPosition" text="📍 Ma position" onAction="#utiliserMaPosition" styleClass="btn-info"/>
                <Button fx:id="btnAjouterFavoris" text="⭐ Ajouter" onAction="#ajouterFavoris" styleClass="btn-warning"/>
            </HBox>

            <Label fx:id="lblStatus" text="Prêt" style="-fx-text-fill: #10B981; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <!-- CENTER: Contenu principal -->
    <center>
        <SplitPane dividerPositions="0.7" orientation="HORIZONTAL" style="-fx-background-color: transparent; -fx-padding: 0 30 30 30;">

            <!-- Panneau gauche : Météo et prévisions -->
            <VBox spacing="20" style="-fx-padding: 0 20 0 0; -fx-background-color: transparent;">

                <!-- Carte météo actuelle -->
                <VBox spacing="15" styleClass="card">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="lblVille" text="Tunis" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #F1F5F9;"/>
                        <Label fx:id="lblDate" text="Loading..." style="-fx-font-size: 14px; -fx-text-fill: #94A3B8;"/>
                    </HBox>

                    <HBox spacing="40" alignment="CENTER_LEFT">
                        <VBox alignment="CENTER_LEFT" spacing="5">
                            <Label fx:id="lblTemperature" text="--°C" style="-fx-font-size: 52px; -fx-font-weight: 900; -fx-text-fill: #10B981;"/>
                            <Label fx:id="lblDescription" text="Chargement..." style="-fx-font-size: 16px; -fx-text-fill: #E2E8F0;"/>
                        </VBox>

                        <VBox spacing="8" style="-fx-padding: 10 0 0 20; -fx-border-color: #334155; -fx-border-width: 0 0 0 1;">
                            <Label fx:id="lblRessentie" text="Ressentie: --°C" style="-fx-text-fill: #CBD5E1;"/>
                            <Label fx:id="lblHumidite" text="Humidité: --%" style="-fx-text-fill: #CBD5E1;"/>
                            <Label fx:id="lblPression" text="Pression: -- hPa" style="-fx-text-fill: #CBD5E1;"/>
                            <Label fx:id="lblVent" text="Vent: -- km/h" style="-fx-text-fill: #CBD5E1;"/>
                            <Label fx:id="lblPluie" text="Pluie: -- mm" style="-fx-text-fill: #CBD5E1;"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="lblConseil" text="Conseil agricole..."
                           style="-fx-background-color: rgba(16,185,129,0.15); -fx-text-fill: #34D399; -fx-padding: 15; -fx-background-radius: 8; -fx-wrap-text: true;"/>
                </VBox>

                <!-- Prévisions -->
                <VBox spacing="10" styleClass="card">
                    <Label text="📅 Prévisions prochaines heures" styleClass="card-title"/>
                    <HBox fx:id="previsionsContainer" spacing="15" alignment="CENTER_LEFT"/>
                </VBox>

                <!-- Tableau des alertes -->
                <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🚨 Alertes météo" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✓ Tout marquer lu" onAction="#marquerToutesLues" styleClass="btn-secondary" style="-fx-padding: 6 12;"/>
                    </HBox>

                    <TableView fx:id="tableAlertes" styleClass="modern-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colIcone" text="" prefWidth="40"/>
                            <TableColumn fx:id="colTitre" text="Alerte" prefWidth="150"/>
                            <TableColumn fx:id="colMessage" text="Message" prefWidth="300"/>
                            <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <!-- Panneau droit : Historique et favoris -->
            <VBox spacing="20" style="-fx-padding: 0 0 0 20; -fx-background-color: transparent;">

                <!-- Historique -->
                <VBox spacing="10" styleClass="card">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📋 Historique" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🗑️ Vider" onAction="#viderHistorique" styleClass="btn-danger" style="-fx-padding: 6 12;"/>
                    </HBox>
                    <ListView fx:id="listHistorique" prefHeight="150" onMouseClicked="#rechercherHistorique"
                              style="-fx-background-color: #0F172A; -fx-border-color: #334155; -fx-border-radius: 8; -fx-control-inner-background: #0F172A;"/>
                </VBox>

                <!-- Favoris -->
                <VBox spacing="10" styleClass="card">
                    <Label text="⭐ Favoris" styleClass="card-title"/>
                    <ListView fx:id="listFavoris" prefHeight="150" onMouseClicked="#rechercherFavori"
                              style="-fx-background-color: #0F172A; -fx-border-color: #334155; -fx-border-radius: 8; -fx-control-inner-background: #0F172A;"/>
                    <Button fx:id="btnSupprimerFavoris" text="❌ Supprimer" onAction="#supprimerFavoris"
                            styleClass="btn-danger" disable="true" maxWidth="Infinity"/>
                </VBox>

                <!-- Villes suggérées -->
                <VBox spacing="10" styleClass="card">
                    <Label text="🌾 Villes agricoles" styleClass="card-title"/>
                    <FlowPane hgap="8" vgap="8">
                        <Button text="Tunis" onAction="#rechercherVille" styleClass="btn-secondary"/>
                        <Button text="Sfax" onAction="#rechercherVille" styleClass="btn-secondary"/>
                        <Button text="Sousse" onAction="#rechercherVille" styleClass="btn-secondary"/>
                        <Button text="Bizerte" onAction="#rechercherVille" styleClass="btn-secondary"/>
                        <Button text="Béja" onAction="#rechercherVille" styleClass="btn-secondary"/>
                        <Button text="Kairouan" onAction="#rechercherVille" styleClass="btn-secondary"/>
                    </FlowPane>
                </VBox>

            </VBox>
        </SplitPane>
    </center>
</BorderPane>