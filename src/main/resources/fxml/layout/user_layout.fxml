<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="core.ui.UserLayoutController"
            prefWidth="1366" prefHeight="768"
            styleClass="main-background"
            stylesheets="@../../css/admin-dark.css">

    <!-- SIDEBAR GAUCHE -->
    <left>
        <ScrollPane fitToWidth="true" pannable="true" styleClass="sidebar-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox prefWidth="255" styleClass="sidebar" spacing="0">

                <!-- En-tête logo -->
                <VBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: #060D1A; -fx-padding: 28 20 22 20; -fx-border-color: #1E3A5F; -fx-border-width: 0 0 1 0;">
                    <Label text="🌾" style="-fx-font-size: 44px; -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.5), 14, 0.5, 0, 0);"/>
                    <Label text="AGRIMANS" style="-fx-font-size: 19px; -fx-font-weight: 900; -fx-text-fill: #F1F5F9; -fx-letter-spacing: 3px;"/>
                    <Label text="Espace Agriculteur" style="-fx-font-size: 10px; -fx-text-fill: #10B981; -fx-font-weight: 700; -fx-letter-spacing: 1px;"/>
                </VBox>

                <!-- Profil -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: #0B1120; -fx-padding: 18 20; -fx-border-color: #1E293B; -fx-border-width: 0 0 1 0;">
                    <StackPane style="-fx-background-radius: 50; -fx-background-color: rgba(16,185,129,0.15); -fx-padding: 14; -fx-min-width: 56; -fx-min-height: 56; -fx-max-width: 56; -fx-max-height: 56;">
                        <Label text="👨‍🌾" style="-fx-font-size: 26px;"/>
                    </StackPane>
                    <Label fx:id="lblUserInfo" text="Agriculteur" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #F1F5F9; -fx-padding: 6 0 0 0;"/>
                    <Label text="En Ligne" style="-fx-font-size: 11px; -fx-text-fill: #10B981;"/>
                </VBox>

                <!-- Menu -->
                <VBox spacing="4" style="-fx-padding: 20 12;">
                    
                    <Label text="MON ESPACE" styleClass="sidebar-section-title"/>
                    <Button text="📊   Tableau de Bord" onAction="#goDashboard" styleClass="sidebar-btn"/>
                    <Button text="📋   Mes Demandes" onAction="#goDemandes" styleClass="sidebar-btn"/>

                    <Region prefHeight="15"/>

                    <Label text="OUTILS &amp; SERVICES" styleClass="sidebar-section-title"/>
                    <Button text="🤖   Assistant IA" onAction="#goChatbot" styleClass="sidebar-btn"/>
                    <Button text="🌤️   Météo Agricole" onAction="#goMeteo" styleClass="sidebar-btn"/>
                    <Button text="🗺️   Carte &amp; Garage" onAction="#goCarte" styleClass="sidebar-btn"/>
                    <Button text="🧠   Analyse Sentiments" onAction="#goSentiment" styleClass="sidebar-btn"/>

                    <Region prefHeight="30"/>

                    <!-- Bouton Déconnexion -->
                    <Button text="🚪   Déconnexion" onAction="#logout" 
                            style="-fx-background-color: rgba(239, 68, 68, 0.1); -fx-text-fill: #EF4444; -fx-font-size: 13px; -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 8;"
                            maxWidth="Infinity"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </left>

    <!-- CONTENU CENTRAL -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #0F172A;"/>
    </center>

</BorderPane>