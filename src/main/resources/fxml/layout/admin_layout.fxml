<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="core.ui.AdminLayoutController"
            prefWidth="1200" prefHeight="700"
            style="-fx-background-color: #F0E8D8;">

    <!-- MENU GAUCHE -->
    <left>
        <VBox spacing="20" prefWidth="250"
              style="-fx-background-color: #2E3D27; -fx-padding: 20;">

            <padding>
                <Insets top="30" right="15" bottom="30" left="15"/>
            </padding>

            <!-- Profil Admin -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="👑" style="-fx-font-size: 50px;"/>
                <Label text="Administrateur" style="-fx-text-fill: #7DBF6C; -fx-font-size: 14px;"/>
                <Label fx:id="lblUserInfo" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

            <Separator style="-fx-background-color: #4B8B3B;"/>

            <!-- Menu de navigation -->
            <VBox spacing="10">
                <Button text="📊 Dashboard" onAction="#goDashboard"
                        style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 12;"
                        prefWidth="220" maxWidth="220"/>

                <Button text="⚙️ Gestion Équipements" onAction="#goEquipements"
                        style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 12;"
                        prefWidth="220" maxWidth="220"/>

                <Button text="⭐ Gestion Reviews" onAction="#goReviews"
                        style="-fx-background-color: #4B8B3B; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 12;"
                        prefWidth="220" maxWidth="220"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bouton déconnexion -->
            <Button text="🚪 Déconnexion" onAction="#logout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 12;"
                    prefWidth="220" maxWidth="220"/>

        </VBox>
    </left>

    <!-- CONTENU CENTRAL -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 20;"/>
    </center>

</BorderPane>